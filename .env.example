# Hermes Dashboard v1.1 Configuration

# Dashboard port (default: 8093)
DASHBOARD_PORT=8093

# Auth (default: admin/admin)
FLASK_USER=admin
FLASK_PASS=changeme

# Vault path for File Viewer tab (optional)
# Expected structure: {VAULT_DIR}/Efforts/Office-Dashboard/
HERMES_VAULT_DIR=C:\Users\YourName\Documents\YourVault

# Scripts config (auto-detected — set only if directory structure differs)
# HERMES_ROOT=C:\path\to\Office-Dashboard
# HERMES_DB_PATH=%LOCALAPPDATA%\hermes\kanban.db
# HERMES_MONITOR_URL=http://localhost:8093
