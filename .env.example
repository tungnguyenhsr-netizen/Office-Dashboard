# Hermes Dashboard v1.1 Configuration

# Dashboard port (default: 8093)
DASHBOARD_PORT=8093

# Hermes vault directory for File Viewer tab (optional)
# Expected structure: {dir}/Efforts/*.md
HERMES_VAULT_DIR=C:\Users\YourName\Documents\YourVault

# Basic auth (optional — leave empty for no auth)
FLASK_USER=admin
FLASK_PASS=changeme
